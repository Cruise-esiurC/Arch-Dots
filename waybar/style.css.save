/* ============================================================
   waybar/style.css  — import colors then use @color variables
   ============================================================ */

@import "colors.css";   /* ← generated by theme-switch.sh */

* {
  font-family: "JetBrainsMono Nerd Font", monospace;
  font-size: 13px;
}

window#waybar {
  background: @bg_bar;
  color: @fg;
  border-bottom: 1px solid @accent_dim;
}

/* modules */
#workspaces button {
  color: @fg_dim;
  padding: 0 6px;
  border-bottom: 2px solid transparent;
}

#workspaces button.active {
  color: @accent;
  border-bottom: 2px solid @accent;
}

#workspaces button:hover {
  color: @accent_glow;
}

#clock,
#cpu,
#memory,
#network,
#pulseaudio,
#tray {
  color: @fg;
  padding: 0 10px;
}

#clock {
  color: @accent;
}

#battery.warning { color: @warn; }
#battery.critical { color: @urgent; }
