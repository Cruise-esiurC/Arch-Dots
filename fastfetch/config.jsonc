{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
 "logo": {
    "source": "~/.config/images/arch.txt",
    "color": {
      "1": "#C4A7E7"
    },
    "padding": {
      "top": 2,
      "right": 6,
      "left": 2
    }
  },
  "display": {
    "separator": " "
  },
  "modules": [
    "break",
    "break",
    {
      "type": "title",
      "keyWidth": 10,
      "color": "#C4A7E7"
    },
    "break",
    {
      "type": "os",
      "key": " ",
      "keyColor": "#c4a7e7",
      "color": "#e0def4",
      "format": "Arch (not Cachy)"
    },
    {
      "type": "custom",
      "key": "🖥 ",
      "keyColor": "#c4a7e7",
      "color": "#e0def4",
      "format": "Cruise"
    },
    {
      "type": "shell",
      "format": "Pain in my dih",
      "key": ">_",
      "keyColor": "#c4a7e7",
      "color": "#e0def4"
    },
    {
      "type": "terminal",
      "key": " ",
      "keyColor": "#c4a7e7",
      "color": "#e0def4"
    },
    {
      "type": "wm",
      "format": "{} (wayland)",
      "key": " ",
      "keyColor": "#c4a7e7",
      "color": "#e0def4"
    },
    {
      "type": "cpu",
      "key": "󰍛 ",
      "keyColor": "#c4a7e7",
      "color": "#e0def4",
      "format": "AMD Ryzen 7 7800X3D"
    },
    {
      "type": "gpu",
      "key": "󰢮 ",
      "keyColor": "#c4a7e7",
      "color": "#e0def4",
      "format": "Nvidia RTX 4070 Super"
    },
    {
      "type": "memory",
      "key": "🎟 ",
      "keyColor": "#c4a7e7",
      "color": "#e0def4",
      "format": "{} {}"
    },
    {
      "type": "uptime",
      "key": " ",
      "keyColor": "#c4a7e7",
      "color": "#e0def4"
    },
    "break",
    "break",
    "break"
  ]
}
